# The URL to your internal or external Frappe instance
# If deploying on the same server in docker, use the internal docker compose network URL (e.g. http://frontend:8080)
ERPNEXT_URL=http://frontend:8080

# Your ERPNext API Key and Secret
# Ensure this API key belongs to a User/Role with heavily restricted permissions
ERPNEXT_API_KEY=your_api_key_here
ERPNEXT_API_SECRET=your_api_secret_here

# (Optional) Port to run the SSE FastMCP server on
PORT=8000

# (Optional) Path to your config.json which holds the whitelisted DocTypes and Auth Tokens
ERPNEXT_MCP_CONFIG=config.json
